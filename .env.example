# Forward Focus Elevation — Environment Template
# Copy to .env.local for local development. Do NOT commit real secrets.

# Frontend (Vite)
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=YOUR_SUPABASE_ANON_KEY
VITE_SUPABASE_PROJECT_ID=YOUR_PROJECT_REF
VITE_ADMIN_SETUP_KEY=REPLACE_WITH_STRONG_SETUP_KEY

# Edge Functions / Supabase Secrets
# Set these in Supabase Dashboard -> Project Settings -> Functions -> Secrets
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY

# AI Providers
OPENAI_API_KEY=YOUR_OPENAI_API_KEY
PERPLEXITY_API_KEY=YOUR_PERPLEXITY_API_KEY

# Email and Payments
RESEND_API_KEY=YOUR_RESEND_API_KEY
STRIPE_SECRET_KEY=YOUR_STRIPE_SECRET_KEY

# Automation / Cron
CRON_SECRET_TOKEN=GENERATE_A_LONG_RANDOM_TOKEN

# Internal admin checks
ADMIN_SETUP_KEY=REPLACE_WITH_STRONG_SETUP_KEY
